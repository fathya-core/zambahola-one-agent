{
  "name": "zambahola-one-agent",
  "version": "0.1.0",
  "private": true,
  "description": "ZAMBAHOLA ONE AGENT v0 — local paper-trading agent",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "agent:start": "npm run start -w @zambahola/one-agent",
    "agent:status": "npm run status -w @zambahola/one-agent",
    "agent:stop": "npm run stop -w @zambahola/one-agent",
    "agent:test-run": "npm run test-run -w @zambahola/one-agent",
    "agent:start:pnpm": "pnpm --filter @zambahola/one-agent start",
    "agent:status:pnpm": "pnpm --filter @zambahola/one-agent status",
    "agent:stop:pnpm": "pnpm --filter @zambahola/one-agent stop",
    "agent:test-run:pnpm": "pnpm --filter @zambahola/one-agent test-run"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
