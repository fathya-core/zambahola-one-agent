{
  "name": "zambahola-one-agent",
  "version": "0.1.0",
  "private": true,
  "description": "ZAMBAHOLA ONE AGENT v0 — local paper-trading agent",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "verify": "node scripts/verify-all.mjs",
    "agent:path-resume": "node scripts/path-resume.mjs",
    "agent:auto-pipeline": "node scripts/autonomous-pipeline.mjs",
    "agent:max-accuracy": "node scripts/max-accuracy-local.mjs train",
    "agent:max-accuracy:quick": "node scripts/max-accuracy-local.mjs train --quick",
    "agent:max-accuracy:start": "node scripts/max-accuracy-local.mjs start",
    "agent:export-models": "npm run export-models -w @zambahola/one-agent",
    "agent:teach-more": "npm run teach-more -w @zambahola/one-agent",
    "agent:restore-weights": "npm run restore-weights -w @zambahola/one-agent",
    "agent:teach-intensive": "npm run teach-intensive -w @zambahola/one-agent",
    "agent:curriculum": "npm run curriculum -w @zambahola/one-agent",
    "agent:omni-train": "node scripts/run-env.mjs --file config/omni-train.env -- npm run omni-train -w @zambahola/one-agent",
    "agent:omni-train:quick": "node scripts/run-env.mjs ZAMBAHOLA_OMNI_EPOCHS=1 ZAMBAHOLA_WF_WINDOWS=2 ZAMBAHOLA_OMNI_KLINES=5000 ZAMBAHOLA_ULTRA_CYCLES=8 ZAMBAHOLA_OMNI_SKIP_CURRICULUM=1 -- npm run omni-train -w @zambahola/one-agent",
    "agent:research-import": "npm run research-import -w @zambahola/one-agent --",
    "agent:import-md-reports": "npm run import-md-reports -w @zambahola/one-agent",
    "agent:start": "npm run start -w @zambahola/one-agent",
    "agent:status": "npm run status -w @zambahola/one-agent",
    "agent:stop": "npm run stop -w @zambahola/one-agent",
    "agent:test-run": "npm run test-run -w @zambahola/one-agent",
    "agent:learn": "npm run learn -w @zambahola/one-agent",
    "agent:turbo-learn": "node scripts/run-env.mjs ZAMBAHOLA_FEED=mock -- npm run learn -w @zambahola/one-agent",
    "agent:backtest": "npm run backtest -w @zambahola/one-agent",
    "agent:power-learn": "npm run power-learn -w @zambahola/one-agent",
    "agent:deep-backtest": "npm run deep-backtest -w @zambahola/one-agent",
    "agent:deep-learn": "npm run deep-learn -w @zambahola/one-agent",
    "agent:mega-train": "npm run mega-train -w @zambahola/one-agent",
    "agent:mega-backtest": "npm run mega-backtest -w @zambahola/one-agent",
    "agent:ultra-learn": "npm run ultra-learn -w @zambahola/one-agent",
    "agent:start:pnpm": "pnpm --filter @zambahola/one-agent start",
    "agent:status:pnpm": "pnpm --filter @zambahola/one-agent status",
    "agent:stop:pnpm": "pnpm --filter @zambahola/one-agent stop",
    "agent:test-run:pnpm": "pnpm --filter @zambahola/one-agent test-run"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
