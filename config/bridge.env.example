# نسخ إلى config/bridge.env على جهازك
# Token عشوائي — نفسه في Cursor secrets إذا تبي السحابة تقرأ

ZAMBAHOLA_BRIDGE_TOKEN=change-me-to-random-32-chars
ZAMBAHOLA_BRIDGE_PORT=8790
ZAMBAHOLA_BRIDGE_PUSH_SEC=60
ZAMBAHOLA_AGENT_URL=http://127.0.0.1:8787

# اختياري — ngrok للوصول من خارج الشبكة
# NGROK_AUTHTOKEN=your_ngrok_token
