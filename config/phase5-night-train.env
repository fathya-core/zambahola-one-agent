# Phase 5 night batch — أطول من quick (~1–2h لكل دورة)
# يُستخدم مع agent:omni-train:night و phase5-night-train.mjs
ZAMBAHOLA_ACCURACY_MODE=max
ZAMBAHOLA_ACCURACY_FILTER=off
ZAMBAHOLA_FEED=mock
ZAMBAHOLA_EXPERT=1
ZAMBAHOLA_STABILIZE=1
ZAMBAHOLA_GUARD_METRIC=directional
ZAMBAHOLA_HORIZON_SEC=45
ZAMBAHOLA_OMNI_KLINES=8000
ZAMBAHOLA_WF_WINDOWS=4
ZAMBAHOLA_OMNI_EPOCHS=2
ZAMBAHOLA_ULTRA_CYCLES=22
ZAMBAHOLA_OMNI_SKIP_CURRICULUM=1
ZAMBAHOLA_CYCLE_MS=65000
