# فتح/قفل DL live تلقائياً داخل الوكيل (بدون أوامر يدوية)
ZAMBAHOLA_DL_LIVE_AUTO=1
ZAMBAHOLA_DL_LIVE_MIN_DIR_ROLLING=0.40
