# جدولة نهار/ليل (يستهلكها phase5-scheduler.mjs)
ZAMBAHOLA_PHASE5_TZ=Asia/Riyadh
ZAMBAHOLA_PHASE5_DAY_START=6
ZAMBAHOLA_PHASE5_NIGHT_START=20
