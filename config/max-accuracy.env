# Copy to repo root as `.env` or source before commands (local machine — full power)
ZAMBAHOLA_ACCURACY_MODE=max
ZAMBAHOLA_EXPERT=1
ZAMBAHOLA_EXPERT_RELAX=1
ZAMBAHOLA_EXPERT_MIN_S_VOTES=1
ZAMBAHOLA_MIN_AGREEMENT=0.52
ZAMBAHOLA_MIN_MODEL_VOTERS=2
ZAMBAHOLA_STABILIZE=0
ZAMBAHOLA_GUARD_METRIC=directional
ZAMBAHOLA_DIR_HIT_FLOOR=0.58
ZAMBAHOLA_ACCURACY_FILTER=live
ZAMBAHOLA_FEED=universal
ZAMBAHOLA_FAST=1
ZAMBAHOLA_TICK_MS=350
ZAMBAHOLA_AUTO_BYBIT=1
ZAMBAHOLA_HORIZON_SEC=45
ZAMBAHOLA_LEARN_CYCLES=30
ZAMBAHOLA_DEEP_CYCLES=25
ZAMBAHOLA_ULTRA_CYCLES=25
ZAMBAHOLA_ULTRA_KLINES=10000
ZAMBAHOLA_KLINES=5000
ZAMBAHOLA_LOB_DEPTH=128
