{
  "mcpServers": {
    "zambahola-local": {
      "command": "node",
      "args": ["mcp-servers/zambahola-local/server.mjs"],
      "env": {
        "ZAMBAHOLA_BRIDGE_URL": "http://127.0.0.1:8790",
        "ZAMBAHOLA_AGENT_URL": "http://127.0.0.1:8787",
        "ZAMBAHOLA_BRIDGE_TOKEN": "paste-from-config-bridge-env"
      }
    },
    "zapier": {
      "url": "https://mcp.zapier.com/api/v1/connect"
    },
    "huggingface-skills": {
      "url": "https://huggingface.co/mcp?login"
    },
    "tavily": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.tavily.com/mcp"],
      "env": {}
    },
    "skills-hub": {
      "command": "npx",
      "args": ["-y", "@skills-hub-ai/mcp"]
    }
  }
}
